# Kopieer dit bestand naar .env.local en vul de waarden in
# Copy this file to .env.local and fill in the values

# Supabase (https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=jouw-anon-key
SUPABASE_SERVICE_ROLE_KEY=jouw-service-role-key

# E-mail via SMTP (bijv. Gmail, Mailgun, Brevo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@maisonamie.fr
SMTP_PASS=jouw-app-wachtwoord
EMAIL_FROM=info@maisonamie.fr
EMAIL_TO=info@maisonamie.fr

# Admin wachtwoord voor het beheerpaneel
ADMIN_PASSWORD=verander-dit-wachtwoord

# Optioneel: geheime sleutel voor sessiescookies
ADMIN_SECRET=willekeurige-geheime-string
